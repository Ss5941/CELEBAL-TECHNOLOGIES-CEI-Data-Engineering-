    "# QUESTION 06\n",
    "from pyspark.sql.functions import col\n",
    "df_revised = (df.withColumnRenamed(\"old_name\", \"new_name\")\n",
    "                .withColumn(\"price\", col(\"price\").cast(\"double\")))\n",
    "\n",
    "df_revised.printSchema()\n",
    "display(df_revised)"
   ]
  },
