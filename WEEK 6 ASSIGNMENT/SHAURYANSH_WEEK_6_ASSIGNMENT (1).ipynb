   "source": [
    "from pyspark.sql import SparkSession\n",
    "from pyspark.sql.types import StructType, StructField, StringType, IntegerType, DoubleType\n",
    "\n",
    "# 1. Creating the  dataset\n",
    "schema = StructType([\n",
    "    StructField(\"product_id\", StringType(), True),\n",
    "    StructField(\"old_name\", StringType(), True),  
    "    StructField(\"category\", StringType(), True),\n",
    "    StructField(\"price\", StringType(), True),     
    "    StructField(\"base_price\", DoubleType(), True),
    "    StructField(\"status\", StringType(), True),    
    "    StructField(\"amount\", IntegerType(), True),   
    "    StructField(\"region\", StringType(), True), 
    "    StructField(\"priority\", StringType(), True),  
    "    StructField(\"user_id\", StringType(), True)    
    "])\n",
    "\n",
    "# 2.  rows for the datasets\n",
    "mock_data = [\n",
    "    (\"P001\", \"Laptop Pro\", \"Electronics\", \"1200.50\", 1200.50, \"Completed\", 1500, \"North\", \"High\", \"USR101\"),\n",
    "    (\"P002\", \"Phone X\", \"Electronics\", \"800.00\", 800.00, \"Pending\", 900, \"South\", \"Low\", \"USR102\"),\n",
    "    (\"P003\", \"Desk Chair\", \"Furniture\", \"150.00\", 150.00, \"Completed\", 300, \"West\", \"High\", None),     
    "    (\"P004\", \"Blender 3000\", \"Appliances\", \"89.99\", 89.99, \"Completed\", 1200, \"North\", \"Low\", \"USR104\"), 
    "    (\"P005\", \"4K Monitor\", \"Electronics\", \"450.00\", 450.00, \"Cancelled\", 450, \"East\", \"Medium\", \"USR105\")\n",
    "]\n",
    "\n",
    "# 3. Create the DataFrame\n",
    "df = spark.createDataFrame(mock_data, schema=schema)\n",
    "\n",
    "# 4. Display the created table \n",
    "display(df)"
   ]
  },
